{
  "name": "governance",
  "description": "治理层",
  "required": false,
  "rules": {
    "blocking": [
      {
        "scope": "change",
        "code": "CHANGE_GOVERNANCE_GATES_REQUIRED",
        "message": "涉及高风险边界时必须满足治理层门禁与裁决点要求"
      }
    ],
    "advisory": [
      {
        "scope": "repository",
        "code": "REPOSITORY_GOVERNANCE_DOCS_REVIEW",
        "message": "仓级治理文档需要持续维护，以防个人流程覆盖团队规则"
      }
    ]
  },
  "files": [
