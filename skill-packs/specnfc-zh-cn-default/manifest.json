  "promptCatalogEntries": [
    {
      "slug": "role",
      "name": "角色 Prompt 目录",
      "entries": [
        "架构师：聚焦边界、约束、接口和长期可维护性。",
        "规划师：聚焦阶段拆分、依赖顺序、验证计划。",
        "执行者：聚焦最小正确改动、严格验证和状态回填。",
        "调试者：聚焦复现、根因、失败路径和修复验证。",
        "评审者：聚焦设计/实现/对接结论、阻断项和建议项。",
        "验证者：聚焦证据、验收结论、剩余风险。",
        "风险审阅者：聚焦阻断、豁免、合规边界和回退。",
        "交付整理者：聚焦 handoff、发布说明和归档收口。"
      ],
      "layer": "prompt",
      "sourcePath": "prompts/role.md"
    },
    {
      "slug": "phase",
      "name": "阶段 Prompt 目录",
      "entries": [
        "需求澄清：统一问题定义、范围、非目标、验收口径。",
        "方案设计：收敛结构、约束、影响面、替代方案与验证思路。",
        "任务规划：拆任务、定验证、定依赖。",
        "执行落地：按 plan 实施并持续回填状态。",
        "系统化调试：先复现、后定位、再修复，保留证据链。",
        "评审复核：形成结构化 review 结论与阻断摘要。",
        "验证验收：形成结果、证据、剩余风险与 accept 结论。",
        "发布交接：形成交付、回退、验证与接手信息。"
      ],
      "layer": "prompt",
      "sourcePath": "prompts/phase.md"
    },
    {
      "slug": "support",
      "name": "辅助 Prompt 目录",
      "entries": [
        "文档规范化：按 document contract 收口文档。",
        "决策提炼：把讨论结果提炼进 decisions.md。",
        "会议记录转 dossier：把过程记录回写到正式 dossier。",
        "writeback：把运行时内容写回正式文档并更新队列。",
        "下一步建议：统一生成标准 next-step 输出。"
      ],
      "layer": "prompt",
      "sourcePath": "prompts/support.md"
    }
  ],
