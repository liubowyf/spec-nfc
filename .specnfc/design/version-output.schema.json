{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "specnfc version --json output",
  "type": "object",
  "required": [
    "ok",
    "command",
    "mode",
    "cwd",
    "data",
    "warnings",
    "next"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "command": {
      "const": "version"
    },
    "mode": {
      "const": "json"
    },
    "cwd": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": "object",
      "required": [
        "specnfcVersion",
        "templateVersion",
        "protocolVersion"
      ],
      "properties": {
        "specnfcVersion": {
          "type": "string"
        },
        "templateVersion": {
          "type": "string"
        },
        "protocolVersion": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
