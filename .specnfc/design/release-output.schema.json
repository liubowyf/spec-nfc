{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "specnfc release script --json output",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "ok",
        "data"
      ],
      "properties": {
        "ok": {
          "const": true
        },
        "data": {
          "type": "object",
          "required": [
            "dryRun",
            "releaseMode",
            "verificationLevel",
            "distribution",
            "version",
            "releaseDir"
          ],
          "properties": {
            "dryRun": {
              "type": "boolean"
            },
            "releaseMode": {
              "type": "string"
            },
            "verificationLevel": {
              "type": "string"
            },
            "distribution": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "releaseDir": {
              "type": "string"
            },
            "packageArtifact": {
              "type": "string"
            },
            "requiredManifests": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "plannedArtifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reportFiles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "installVerification": {
              "type": "object",
              "additionalProperties": true
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "label"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": [
        "ok",
        "error"
      ],
      "properties": {
        "ok": {
          "const": false
        },
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "details"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "details": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
