{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "specnfc bootstrap script --json output",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "ok",
        "mode",
        "cwd",
        "data"
      ],
      "properties": {
        "ok": {
          "const": true
        },
        "mode": {
          "const": "json"
        },
        "cwd": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "required": [
            "nodeVersion",
            "dryRun",
            "skipTest",
            "skipLink",
            "steps",
            "successCriteria"
          ],
          "properties": {
            "nodeVersion": {
              "type": "string"
            },
            "dryRun": {
              "type": "boolean"
            },
            "skipTest": {
              "type": "boolean"
            },
            "skipLink": {
              "type": "boolean"
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "label",
                  "command",
                  "status"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "command": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "exitCode": {
                    "type": "integer"
                  },
                  "stdout": {
                    "type": "string"
                  },
                  "stderr": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            },
            "successCriteria": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": [
        "ok",
        "mode",
        "cwd",
        "error",
        "data"
      ],
      "properties": {
        "ok": {
          "const": false
        },
        "mode": {
          "const": "json"
        },
        "cwd": {
          "type": "string"
        },
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "failedStep",
            "details"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "failedStep": {
              "type": [
                "string",
                "null"
              ]
            },
            "details": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "data": {
          "type": "object",
          "required": [
            "nodeVersion",
            "steps"
          ],
          "properties": {
            "nodeVersion": {
              "type": "string"
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "label",
                  "command",
                  "status"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "command": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "exitCode": {
                    "type": "integer"
                  },
                  "stdout": {
                    "type": "string"
                  },
                  "stderr": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  ]
}
